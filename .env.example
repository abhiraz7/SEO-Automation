# Copy this file to .env and fill in real values. Never commit .env itself
# (it's already gitignored) — this file only documents which variables the
# app reads and what they're for. All values below are placeholders.

# --- AI suggestions (required) ---
# Claude API key used to generate SEO fix suggestions and page-understanding
# context. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Keyword data providers (at least one required for Keyword Research / Rank Tracking) ---
# Semrush is tried first for keyword overview/bulk lookups.
# https://www.semrush.com/api-documentation/
SEMRUSH_API_KEY=

# DataForSEO is tried first for SERP checks (rank tracking) and related/
# question keyword suggestions, falling back to Semrush if unset or down.
# Uses HTTP Basic Auth (login/password), not a single key.
# IMPORTANT: a new DataForSEO account must be verified in their dashboard
# (https://app.dataforseo.com/) before the API will accept any call —
# otherwise every request 403s even with valid credentials.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- WordPress deploy (required to use the WordPress Auto-Deploy feature) ---
# Fernet encryption key for WordPress API tokens stored at rest in the DB.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WP_TOKEN_KEY=

# --- Optional / not yet wired into the app ---
# Supabase push functions exist in app/supabase_client.py but currently have
# no callers anywhere in the app — safe to leave blank.
SUPABASE_URL=
SUPABASE_KEY=
